<div class="mb-4">
  <h1 class="display-4 fw-bold mb-1"><%= @company["name"] %></h1>
  <p class="text-muted fs-5"><%= @company["city"] %>, <%= @company["state"] %></p>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card h-100 shadow-sm">
      <div class="card-body">
        <h3 class="h4 mb-4">Contacts</h3>

        <% if @contacts.count == 0 %>
          <p class="text-muted">No contacts yet.</p>
        <% end %>

        <% for contact in @contacts %>
          <div class="mb-3">
            <a href="/contacts/<%= contact["id"] %>" class="text-decoration-none fw-semibold">
              <%= contact["last_name"] %>, <%= contact["first_name"] %>
            </a>
          </div>
        <% end %>

        <a href="/contacts/new?company_id=<%= @company["id"] %>" class="btn btn-primary mt-2">
          New Contact
        </a>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <h3 class="h4 mb-4">Company Details</h3>

        <p><strong>Name:</strong> <%= @company["name"] %></p>
        <p><strong>Location:</strong> <%= @company["city"] %>, <%= @company["state"] %></p>

        <div class="mt-4 d-flex flex-wrap gap-2">
          <a href="/companies" class="btn btn-secondary">Back to All Companies</a>

          <% if User.find_by({ "id" => session["user_id"] }) != nil %>
            <a href="/companies/<%= @company["id"] %>/edit" class="btn btn-outline-primary">Edit Company</a>

            <form action="/companies/<%= @company["id"] %>" method="post" class="d-inline">
              <input type="hidden" name="_method" value="delete">
              <button class="btn btn-outline-danger">Delete Company</button>
            </form>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <h3 class="h4 mb-3">Sales Activity</h3>
        <p class="text-muted mb-0">View an individual contact to see sales activity.</p>
      </div>
    </div>
  </div>
</div>